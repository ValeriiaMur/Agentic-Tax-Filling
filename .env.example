# Copy to .env (or set in Railway dashboard). All are optional for the core flow.

# Enables Claude vision for W-2 image/PDF extraction and (optionally) warm phrasing.
# Without it, the app still works end-to-end via the paste / structured-form path.
ANTHROPIC_API_KEY=

# Set to 1 to have Claude lightly rephrase the agent's messages (numbers preserved).
USE_LLM_PHRASING=0

# Models (defaults shown).
VISION_MODEL=claude-3-5-sonnet-20241022
CHAT_MODEL=claude-3-5-sonnet-20241022

# Where generated PDFs are written (defaults to ./_outputs).
OUTPUT_DIR=
