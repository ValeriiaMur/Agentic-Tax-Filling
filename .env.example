# Copy to .env (or set in Railway dashboard). All are optional for the core flow.

# Enables Claude for W-2 image/PDF vision extraction AND warm, varied phrasing of
# the agent's messages. Without it, the app still works end-to-end via the
# paste / sample-W-2 path, with the deterministic (template) wording.
ANTHROPIC_API_KEY=

# Claude-generated phrasing is ON by default when a key is set. Set to 0 to force
# the deterministic template wording. Every dollar amount is preserved either way.
LLM_PHRASING=1

# Models (cheap + fast defaults; numbers are never trusted to the model).
VISION_MODEL=claude-haiku-4-5
CHAT_MODEL=claude-haiku-4-5

# Where generated PDFs are written (defaults to ./_outputs).
OUTPUT_DIR=
